{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "startCommand": "gunicorn -w 2 --threads 8 --timeout 600 --keep-alive 30 --worker-class gthread --max-requests 500 --max-requests-jitter 50 --graceful-timeout 60 -b 0.0.0.0:$PORT crackpro:app"
  }
}
